      "path": "orders"
    },
    {
      "id": "summary",
      "label": "요약 데이터",
      "description": "합계와 같은 요약 영역에서 사용하는 데이터입니다.",
      "url": "/report-data/monthly-sales.json",
      "path": ""
    }
